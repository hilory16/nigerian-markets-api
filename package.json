{
  "name": "iya-oloja",
  "description": "Nigerian Markets API — an open directory of markets across Nigeria",
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm run build && wrangler pages deploy dist --project-name iya-oloja --branch main",
    "seed": "pnpm exec tsx scripts/seed-states.ts",
    "validate": "pnpm exec tsx scripts/validate-data.ts",
    "sync": "pnpm exec tsx scripts/sync-to-d1.ts",
    "db:migrate": "wrangler d1 execute iya-oloja --local --file=migrations/0001_create_tables.sql"
  },
  "dependencies": {
    "hono": "^4.1.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@hono/vite-cloudflare-pages": "^0.2.4",
    "@hono/vite-dev-server": "^0.10.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vite": "^5.0.12",
    "wrangler": "^3.32.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
}
